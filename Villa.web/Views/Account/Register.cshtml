                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3 border-0 rounded-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label fw-bold small text-muted text-uppercase">Full Name</label>
