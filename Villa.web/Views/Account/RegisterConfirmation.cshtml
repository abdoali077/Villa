@{
    ViewData["Title"] = "Confirm Your Email";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 text-center">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary py-2"></div>

                <div class="card-body p-5">
                    <div class="mb-4">
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary d-inline-flex align-items-center justify-content-center mb-3">
                            <i class="bi bi-envelope-paper-heart fs-1"></i>
                        </div>
                    </div>

                    <h2 class="fw-bold text-dark">Registration Successful! 🎉</h2>

                    <p class="text-muted fs-5 mt-3">
                        We've sent a magic link to your email address. Please click it to verify your account and start your luxury experience.
                    </p>

                    <div class="mt-4 p-4 bg-light rounded-4 text-start">
                        <h6 class="fw-bold mb-3 small text-uppercase text-primary"><i class="bi bi-lightbulb me-2"></i>Quick Tips:</h6>
                        <ul class="list-unstyled small text-muted mb-0">
                            <li class="mb-2"><i class="bi bi-check2-circle me-2 text-success"></i>Check your <strong>Spam</strong> or Junk folder if you don't see it.</li>
                            <li class="mb-2"><i class="bi bi-check2-circle me-2 text-success"></i>The link is valid for 24 hours.</li>
                            <li><i class="bi bi-check2-circle me-2 text-success"></i>Make sure you're looking at the right email inbox.</li>
                        </ul>
                    </div>

                    <div class="mt-5 d-flex flex-column gap-3">
                        <a href="https://mail.google.com" target="_blank" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm transition-up">
                            <i class="bi bi-box-arrow-up-right me-2"></i> Open Webmail
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-link text-decoration-none text-muted fw-medium small">
                            I'll do this later, take me Home
                        </a>
                    </div>
                </div>

                <div class="card-footer bg-white border-0 py-4 border-top">
                    <p class="text-muted small mb-0">
                        Didn't get the email? <a href="#" class="text-primary fw-bold text-decoration-none">Resend link</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: #f4f7f6;
    }

    .icon-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        animation: pulse-blue 2s infinite;
    }

    .transition-up:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(13, 110, 253, 0.2) !important;
    }

    @@keyframes pulse-blue {
        0% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.4);
        }

        70% {
            transform: scale(1);
            box-shadow: 0 0 0 15px rgba(13, 110, 253, 0);
        }

        100% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(13, 110, 253, 0);
        }
    }

    .card {
        border: none;
    }
</style>