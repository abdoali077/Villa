@section Scripts {
    <script src="~/js/IndexHome.js" asp-append-version="true"></script>
}
<style>
    /* Hero Style */
    .hero-bg {
        background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1580587771525-78b9dba3b914?auto=format&fit=crop&w=1600&q=80');
        background-size: cover;
        background-position: center;
        border-radius: 0 0 50px 50px;
        min-height: 450px;
        display: flex;
        align-items: center;
    }

    /* Search Bar Responsive Logic */
    .search-wrapper {
        margin-top: -60px; /* Adjusted from -100px for mobile safety */
        position: relative;
        z-index: 10;
        padding: 0 15px;
    }

    .search-card {
        background: white;
        border-radius: 100px; /* Default Pill */
        padding: 5px;
    }

    /* Mobile & Tablet Adjustments */
    @@media (max-width: 991.98px) {
        .search-card {
            border-radius: 25px !important; /* Switch from Pill to Rounded Square */
            padding: 15px;
        }

        .search-wrapper {
            margin-top: -40px;
        }

        .search-item {
            border-bottom: 1px solid #f0f0f0;
            margin-bottom: 5px;
        }

            .search-item:last-of-type {
                border-bottom: none;
            }
    }

    /* Desktop Borders */
    @@media (min-width: 992px) {
        .border-end-lg {
            border-right: 1px solid #eee !important;
        }

        .search-card {
            padding: 5px 5px 5px 25px;
        }
    }

    /* Villa Cards Hover */
    .villa-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
    }

        .villa-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    /* Modal Backdrop */
    .modal-backdrop.show {
        opacity: 0.7;
        backdrop-filter: blur(4px);
    }

    .animate-up {
        animation: fadeInUp 0.8s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>


