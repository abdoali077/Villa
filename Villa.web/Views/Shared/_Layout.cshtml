<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Villa.web</title>
    @await RenderSectionAsync("Styles", required: false)
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/apexcharts.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top py-3 shadow-sm">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <img src="~/Images/resort.png" alt="Logo" style="height: 35px;" />
                    <span class="ms-2 fw-bold text-primary fs-4" style="letter-spacing: 1px;">VILLA<span class="text-dark">WEB</span></span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link fw-medium px-3" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item dropdown">
                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                @if (User.IsInRole("Admin"))
                                {
                                    <!-- Admin Menu -->
                                <li class="nav-item dropdown">

                                    <a class="nav-link dropdown-toggle fw-medium px-3"
                                       href="#"
                                       role="button"
                                       data-bs-toggle="dropdown">

                                        Admin Tools
                                    </a>

                                    <ul class="dropdown-menu border-0 shadow-lg mt-3 rounded-3">

                                        <li>
                                            <h6 class="dropdown-header small text-muted text-uppercase">
                                                Management
                                            </h6>
                                        </li>

                                        <li>
                                            <a class="dropdown-item py-2"
                                               asp-controller="Villas"
                                               asp-action="Index">
                                                <i class="bi bi-house-door me-2 text-primary"></i>
                                                Villas
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item py-2"
                                               asp-controller="Amenity"
                                               asp-action="Index">
                                                <i class="bi bi-star me-2 text-warning"></i>
                                                Amenities
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item py-2"
                                               asp-controller="VillaNumber"
                                               asp-action="Index">
                                                <i class="bi bi-hash me-2 text-success"></i>
                                                Villa Numbers
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item py-2"
                                               asp-controller="Booking"
                                               asp-action="Index">
                                                <i class="bi bi-calendar-check me-2 text-info"></i>
                                                Bookings
                                            </a>
                                        </li>

                                    </ul>
                                </li>
                            }
                            else
                            {
                                <!-- Normal User -->
                                <li class="nav-item">
                                    <a class="nav-link fw-medium px-3"
                                       asp-controller="Booking"
                                       asp-action="Index">
                                        My Bookings
                                    </a>
                                </li>
                            }
                        }

                    </ul>


                   
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="content-wrapper">
        <main role="main">
            <partial name="_Notification" />
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-light pt-5 pb-3 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h5 class="fw-bold mb-4 text-white">VILLA<span class="text-primary">WEB</span></h5>
                    <p class="text-muted small w-75">Your ultimate destination for luxury stays. We provide the best-curated villas with world-class amenities.</p>
                    <div class="d-flex gap-3 mt-3">
                        <a href="#" class="text-muted fs-5"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-muted fs-5"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-muted fs-5"><i class="bi bi-twitter-x"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-6">
                    <h6 class="fw-bold mb-4">Quick Links</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none hover-link">Home</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none hover-link">Privacy Policy</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-6">
                    <h6 class="fw-bold mb-4">Support</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#" class="text-muted text-decoration-none hover-link">Contact Us</a></li>
                        <li class="mb-2"><a href="#" class="text-muted text-decoration-none hover-link">FAQ</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <h6 class="fw-bold mb-4">Newsletter</h6>
                    <div class="input-group mb-3 shadow-sm">
                        <input type="text" class="form-control border-0 bg-secondary bg-opacity-10 text-white small" placeholder="Your Email">
                        <button class="btn btn-primary btn-sm px-3"><i class="bi bi-send"></i></button>
                    </div>
                </div>
            </div>
            <hr class="mt-5 mb-4 opacity-25">
            <div class="text-center small text-muted">
                &copy; @DateTime.Now.Year - Made with <i class="bi bi-heart-fill text-danger mx-1"></i> by Dotnet Mastery
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @* <script src="~/js/apexcharts.min.js"></script> *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>