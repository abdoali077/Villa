@model AmenityVM

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                @* Header *@
                <div class="card-header bg-danger bg-gradient text-white py-4 border-0">
                    <div class="d-flex align-items-center justify-content-center">
                        <i class="bi bi-exclamation-triangle-fill fs-2 me-3"></i>
                        <h2 class="mb-0 fw-bold">Delete Amenity</h2>
                    </div>
                </div>

                <div class="card-body p-5 bg-light">

                    @* 🔥 Enhanced Alert *@
                    <div class="alert alert-danger border-0 shadow-lg mb-4 p-4 rounded-4 position-relative overflow-hidden">

                        @* Top Accent Line *@
                        <div class="position-absolute top-0 start-0 w-100" style="height:4px; background: linear-gradient(90deg,#ff4d4f,#ff7875);"></div>

                        <div class="d-flex align-items-start">
                            <div class="me-3">
                                <i class="bi bi-exclamation-triangle-fill fs-2 text-danger"></i>
                            </div>

                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-2 text-danger">
                                    Danger Zone
                                </h5>

                                <p class="mb-2 fw-semibold">
                                    Are you absolutely sure you want to delete this Amenity?
                                </p>

                                <p class="mb-0 text-muted small">
                                    This action is <span class="fw-bold text-danger">permanent</span> and cannot be undone.
                                </p>
                            </div>
                        </div>
                    </div>

                    <form method="post" class="row g-4">

                        <input asp-for="Amenity.Id" hidden />

                        @* Name *@
                        <div class="col-md-12">
                            <div class="form-floating">
                                <input asp-for="Amenity.Name" disabled class="form-control border-0 shadow-sm bg-white" readonly />
                                <label asp-for="Amenity.Name" class="ms-2">Amenity Name</label>
                            </div>
                        </div>

                        @* SpecialDetails *@
                        <div class="col-12">
                            <div class="form-floating">
                                <textarea asp-for="Amenity.Description" disabled class="form-control border-0 shadow-sm bg-white" style="height: 100px"></textarea>
                                <label asp-for="Amenity.Description" class="ms-2">Amenity Description</label>
                            </div>
                        </div>

                        @* Action Buttons *@
                        <div class="col-12 mt-5">
                            <div class="row g-3">
                                <div class="col-md-6">

                                    <button type="submit"
                                            onclick="return confirm('Final warning: This action cannot be undone. Are you sure?')"
                                            class="btn btn-danger w-100 py-3 rounded-3 shadow-sm fw-bold">
                                        <i class="bi bi-trash3-fill me-2"></i> Yes, Delete Permanently
                                    </button>
                                </div>
                                <div class="col-md-6">
                                    <a asp-controller="Amenity" asp-action="Index"
                                       class="btn btn-secondary w-100 py-3 rounded-3 shadow-sm fw-bold">
                                        Cancel & Go Back
                                    </a>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>