@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<div class="d-flex align-items-center gap-3">
    @if (SignInManager.IsSignedIn(User))
    {
        <div class="dropdown">
            <a class="btn btn-outline-primary rounded-pill px-4 fw-medium dropdown-toggle d-flex align-items-center shadow-sm"
               href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person-circle me-2 fs-5"></i>
                <span class="d-none d-sm-inline">Hello, @(UserManager.GetUserAsync(User).Result?.Name ?? UserManager.GetUserName(User))</span>
            </a>

            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-3 rounded-3">
                <li>
                    <div class="dropdown-header d-flex align-items-center p-3 border-bottom mb-2">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;">
                            <i class="bi bi-person fs-4"></i>
                        </div>
                        <div>
                            <p class="mb-0 fw-bold text-dark">@UserManager.GetUserName(User)</p>
                            <small class="text-muted">Managed Account</small>
                        </div>
                    </div>
                </li>
                <li>
                    <a class="dropdown-item py-2" asp-controller="Booking" asp-action="Index">
                        <i class="bi bi-journal-bookmark me-2 text-primary"></i> My Bookings
                    </a>
                </li>
                <li>
                    <a class="dropdown-item py-2" href="#">
                        <i class="bi bi-gear me-2 text-secondary"></i> Settings
                    </a>
                </li>
                <li><hr class="dropdown-divider opacity-50"></li>
                <li>
                    <form method="post" asp-area="" asp-controller="Account" asp-action="Logout" class="px-2">
                        <button type="submit" class="btn btn-danger w-100 rounded-pill py-2 btn-sm fw-bold shadow-sm">
                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    }
    else
    {
        <a class="btn btn-outline-primary rounded-pill px-4 fw-medium transition-up" asp-area="" asp-controller="Account" asp-action="Login">
            <i class="bi bi-box-arrow-in-right me-1"></i> Login
        </a>
        <a class="btn btn-primary rounded-pill px-4 fw-medium shadow-sm transition-up" asp-area="" asp-controller="Account" asp-action="Register">
            Register
        </a>
    }
</div>

<style>
    /* تحسين شكل الـ Dropdown Item */
    .dropdown-item {
        transition: all 0.2s ease;
        border-radius: 8px;
        margin: 0 8px;
        width: calc(100% - 16px);
    }

        .dropdown-item:hover {
            background-color: #f8f9fa;
            transform: translateX(5px);
            color: #0d6efd;
        }

    .transition-up:hover {
        transform: translateY(-2px);
    }
</style>